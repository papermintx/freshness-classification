*.py[cod]
*$py.class
*.egg-info/
.env
.venv/
venv/
env/

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# Output sementara
modeling/outputs/cleaned_data/
modeling/outputs/cleaned_testings/

# ------------------------------------------------------------
# OS-specific
# ------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
*.log
