visualisasi_pengujian_inferensi_dan_jarak/dataset/**/*.JPEG
visualisasi_pengujian_inferensi_dan_jarak/dataset/**/*.PNG

# ------------------------------------------------------------
# Android Build (CnnFreshScan)
# ------------------------------------------------------------
CnnFreshScan/.gradle/
CnnFreshScan/build/
CnnFreshScan/**/build/
CnnFreshScan/local.properties
CnnFreshScan/*.apk
CnnFreshScan/*.aab
CnnFreshScan/*.aar
CnnFreshScan/*.ap_
CnnFreshScan/*.jks
CnnFreshScan/*.keystore
CnnFreshScan/*.pk8
CnnFreshScan/*.pem
CnnFreshScan/release.properties
