# ------------------------------------------------------------
CnnFreshScan/.gradle/
CnnFreshScan/build/
CnnFreshScan/**/build/
CnnFreshScan/local.properties
CnnFreshScan/*.apk
CnnFreshScan/*.aab
CnnFreshScan/*.aar
CnnFreshScan/*.ap_
CnnFreshScan/*.jks
CnnFreshScan/*.keystore
CnnFreshScan/*.pk8
CnnFreshScan/*.pem
CnnFreshScan/captures/
CnnFreshScan/.kotlin/

# Android Studio / IntelliJ IDEA
CnnFreshScan/.idea/caches/
CnnFreshScan/.idea/libraries/
CnnFreshScan/.idea/modules.xml
CnnFreshScan/.idea/workspace.xml
CnnFreshScan/.idea/navEditor.xml
CnnFreshScan/.idea/assetWizardSettings.xml
CnnFreshScan/.idea/deploymentTargetSelector.xml
CnnFreshScan/.idea/androidTestResultsUserPreferences.xml
