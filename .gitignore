# Android Studio / IntelliJ IDEA (semua di-ignore)
CnnFreshScan/.idea/
CnnFreshScan/*.iml
CnnFreshScan/*.ipr
CnnFreshScan/*.iws

# ------------------------------------------------------------
# Python (Modeling & Visualisasi)
# ------------------------------------------------------------
